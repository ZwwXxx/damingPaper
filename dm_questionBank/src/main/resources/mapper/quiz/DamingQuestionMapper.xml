<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dm.quiz.mapper.DamingQuestionMapper">

    <resultMap type="DamingQuestion" id="DamingQuestionResult">
        <result property="id"           column="id" />
        <result property="parentId"     column="parent_id" />
        <result property="questionType" column="question_type" />
        <result property="clozeIndex"   column="cloze_index" />
        <result property="originOrder"  column="origin_order" />
        <result property="questionInfoId" column="question_info_id" />
        <result property="animationId"  column="animation_id" />
        <result property="correct"      column="correct" />
        <result property="score"        column="score" />
        <result property="difficulty"   column="difficulty" />
        <result property="delFlag"      column="del_flag" />
        <result property="subjectId"    column="subject_id" />
        <result property="examYear"     column="exam_year" />
        <result property="examHalf"     column="exam_half" />
        <result property="createTime"   column="create_time" />
        <result property="updateTime"   column="update_time" />
    </resultMap>

    <sql id="selectDamingQuestionVo">
        select q.id,
               q.parent_id,
               q.question_type,
               q.cloze_index,
               q.origin_order,
               q.question_info_id,
               q.animation_id,
               q.correct,
               q.score,
               q.difficulty,
               q.del_flag,
               q.subject_id,
               q.exam_year,
               q.exam_half,
               q.create_time,
               q.update_time
        from daming_question q
    </sql>

    <select id="selectDamingQuestionList" parameterType="DamingQuestion" resultMap="DamingQuestionResult">
        <include refid="selectDamingQuestionVo"/>
        left join daming_content_info ci on ci.id = q.question_info_id
        <where>
            <!-- 默认仅查询顶层题目：parent_id 为空或 0；当显式传入 parentId 时，查询对应父题下的子题 -->
            <if test="parentId != null">
                and q.parent_id = #{parentId}
            </if>
            <if test="parentId == null">
                and (q.parent_id is null or q.parent_id = 0)
            </if>
            <if test="questionType != null ">and q.question_type = #{questionType}</if>
            <if test="questionInfoId != null ">and q.question_info_id = #{questionInfoId}</if>
            <if test="score != null ">and q.score = #{score}</if>
            <if test="subjectId != null ">and q.subject_id = #{subjectId}</if>
            <if test="examYear != null ">and q.exam_year = #{examYear}</if>
            <if test="examHalf != null ">and q.exam_half = #{examHalf}</if>
            <if test="createTime != null ">and q.create_time = #{createTime}</if>
            <if test="updateTime != null ">and q.update_time = #{updateTime}</if>
            <if test="questionTitle != null and questionTitle != ''">
                and json_unquote(json_extract(ci.content, '$.questionTitle')) like concat('%', #{questionTitle}, '%')
            </if>
            <if test="_parameter != null and params != null and params.beginTime != null and params.beginTime != ''"><!-- 开始时间检索 -->
                AND date_format(q.create_time,'%Y%m%d') &gt;= date_format(#{params.beginTime},'%Y%m%d')
            </if>
            <if test="_parameter != null and params != null and params.endTime != null and params.endTime != ''"><!-- 结束时间检索 -->
                AND date_format(q.create_time,'%Y%m%d') &lt;= date_format(#{params.endTime},'%Y%m%d')
            </if>
            and q.del_flag!=2
        </where>
        order by q.create_time desc
    </select>

    <select id="selectDamingQuestionById" parameterType="Long" resultMap="DamingQuestionResult">
        <include refid="selectDamingQuestionVo"/>
        where q.id = #{id}
    </select>
    <select id="selectQuestionListByIds" resultMap="DamingQuestionResult">
        <include refid="selectDamingQuestionVo"/>
        WHERE q.id IN
        <foreach item="id" collection="ids" open="(" separator="," close=")">
            #{id}
        </foreach>
        and q.del_flag!=2
    </select>

    <select id="selectRandomQuestions" resultMap="DamingQuestionResult">
        <include refid="selectDamingQuestionVo"/>
        WHERE q.del_flag != 2
          AND (q.parent_id IS NULL OR q.parent_id = 0)
        <if test="subjectId != null">
            AND q.subject_id = #{subjectId}
        </if>
        <if test="questionType != null">
            AND q.question_type = #{questionType}
        </if>
        ORDER BY rand()
        LIMIT #{limit}
    </select>

    <!-- 按科目 + 创建日期范围查询题目列表（用于按日期自动组卷） -->
    <select id="selectQuestionsBySubjectAndCreateTime" resultMap="DamingQuestionResult">
        <include refid="selectDamingQuestionVo"/>
        <where>
            and q.del_flag != 2
            and (q.parent_id IS NULL OR q.parent_id = 0)
            <if test="subjectId != null">
                AND q.subject_id = #{subjectId}
            </if>
            <if test="beginTime != null and beginTime != ''">
                AND date_format(q.create_time,'%Y%m%d') &gt;= date_format(#{beginTime},'%Y%m%d')
            </if>
            <if test="endTime != null and endTime != ''">
                AND date_format(q.create_time,'%Y%m%d') &lt;= date_format(#{endTime},'%Y%m%d')
            </if>
        </where>
        ORDER BY q.create_time ASC
    </select>

    <insert id="insertDamingQuestion" parameterType="DamingQuestion">
        insert into daming_question
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="parentId != null">parent_id,</if>
            <if test="questionType != null">question_type,</if>
            <if test="clozeIndex != null">cloze_index,</if>
            <if test="originOrder != null">origin_order,</if>
            <if test="questionInfoId != null">question_info_id,</if>
            <if test="animationId != null">animation_id,</if>
            <if test="correct != null">correct,</if>
            <if test="score != null">score,</if>
            <if test="difficulty != null">difficulty,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="subjectId != null">subject_id,</if>
            <if test="examYear != null">exam_year,</if>
            <if test="examHalf != null">exam_half,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="parentId != null">#{parentId},</if>
            <if test="questionType != null">#{questionType},</if>
            <if test="clozeIndex != null">#{clozeIndex},</if>
            <if test="originOrder != null">#{originOrder},</if>
            <if test="questionInfoId != null">#{questionInfoId},</if>
            <if test="animationId != null">#{animationId},</if>
            <if test="correct != null">#{correct},</if>
            <if test="score != null">#{score},</if>
            <if test="difficulty != null">#{difficulty},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="subjectId != null">#{subjectId},</if>
            <if test="examYear != null">#{examYear},</if>
            <if test="examHalf != null">#{examHalf},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateDamingQuestion" parameterType="DamingQuestion">
        update daming_question
        <trim prefix="SET" suffixOverrides=",">
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="questionType != null">question_type = #{questionType},</if>
            <if test="clozeIndex != null">cloze_index = #{clozeIndex},</if>
            <if test="originOrder != null">origin_order = #{originOrder},</if>
            <if test="questionInfoId != null">question_info_id = #{questionInfoId},</if>
            <if test="animationId != null">animation_id = #{animationId},</if>
            <if test="correct != null">correct = #{correct},</if>
            <if test="score != null">score = #{score},</if>
            <if test="difficulty != null">difficulty = #{difficulty},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="subjectId != null">subject_id = #{subjectId},</if>
            <if test="examYear != null">exam_year = #{examYear},</if>
            <if test="examHalf != null">exam_half = #{examHalf},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <!-- 仅更新原卷题号 -->
    <update id="updateOriginOrder">
        update daming_question
        set origin_order = #{originOrder}
        where id = #{id}
    </update>

    <!-- 仅更新考试批次（上/下半年） -->
    <update id="updateExamHalf">
        update daming_question
        set exam_half = #{examHalf}
        where id = #{id}
    </update>

    <!-- 批量更新年份/批次，null 表示不更新该字段 -->
    <update id="batchUpdateExamMeta">
        update daming_question
        <set>
            <if test="examYear != null">exam_year = #{examYear},</if>
            <if test="examHalf != null">exam_half = #{examHalf},</if>
            update_time = now()
        </set>
        where id in
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        and del_flag != 2
    </update>

    <delete id="deleteDamingQuestionById" parameterType="Long">
        delete from daming_question where id = #{id}
    </delete>

    <delete id="deleteDamingQuestionByIds" parameterType="String">
        update   daming_question
        set del_flag=2
        where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
