<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.KnowledgeTagMapper">

    <resultMap type="com.ruoyi.system.domain.KnowledgeTag" id="KnowledgeTagResult">
        <result property="tagId"     column="tag_id"     />
        <result property="tagName"   column="tag_name"  />
        <result property="tagColor"  column="tag_color" />
        <result property="useCount"  column="use_count" />
        <result property="createTime" column="create_time" />
    </resultMap>

    <sql id="selectKnowledgeTagVo">
        select tag_id, tag_name, tag_color, use_count, create_time
        from knowledge_tag
    </sql>

    <select id="selectKnowledgeTagByTagId" parameterType="Long" resultMap="KnowledgeTagResult">
        <include refid="selectKnowledgeTagVo"/>
        where tag_id = #{tagId}
    </select>

    <select id="selectByTagName" resultMap="KnowledgeTagResult">
        <include refid="selectKnowledgeTagVo"/>
        where tag_name = #{tagName} limit 1
    </select>

    <select id="selectKnowledgeTagList" parameterType="com.ruoyi.system.domain.KnowledgeTag" resultMap="KnowledgeTagResult">
        <include refid="selectKnowledgeTagVo"/>
        <where>
            <if test="tagName != null and tagName != ''">
                AND tag_name like concat('%', #{tagName}, '%')
            </if>
        </where>
        order by use_count desc, create_time desc
    </select>

    <insert id="insertKnowledgeTag" parameterType="com.ruoyi.system.domain.KnowledgeTag" useGeneratedKeys="true" keyProperty="tagId">
        insert into knowledge_tag (tag_name, tag_color, use_count, create_time)
        values (#{tagName}, #{tagColor}, #{useCount}, sysdate())
    </insert>

    <update id="updateKnowledgeTag" parameterType="com.ruoyi.system.domain.KnowledgeTag">
        update knowledge_tag
        <set>
            <if test="tagName != null and tagName != ''">tag_name = #{tagName},</if>
            <if test="tagColor != null">tag_color = #{tagColor},</if>
            <if test="useCount != null">use_count = #{useCount},</if>
        </set>
        where tag_id = #{tagId}
    </update>

    <delete id="deleteKnowledgeTagByTagId" parameterType="Long">
        delete from knowledge_tag where tag_id = #{tagId}
    </delete>

    <delete id="deleteKnowledgeTagByTagIds" parameterType="Long">
        delete from knowledge_tag where tag_id in
        <foreach item="tagId" collection="array" open="(" separator="," close=")">
            #{tagId}
        </foreach>
    </delete>
</mapper>
